# ProdVideo AI Factory - 本地开发环境配置
# Redis（本地便携版，无密码）
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# MySQL（需手动安装，安装后修改下方配置）
MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PASSWORD=root
MYSQL_DATABASE=prodvideo

# Celery（使用 Redis 作为 broker，无需 RabbitMQ）
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/0

# MinIO（暂未安装，配置保留；服务启动不会报错，MinIO 操作时才连接）
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin2024

# MongoDB（暂未安装，非必需）
MONGODB_HOST=localhost
MONGODB_PORT=27017
MONGODB_DATABASE=prodvideo

# JWT Secret
INTERNAL_JWT_SECRET=dev-jwt-secret-prodvideofactory-2024

# 安全开关（开发模式）
MCP_AUTH_DISABLED=true
NACOS_ENABLED=false
VAULT_ENABLED=false
CONTENT_SAFETY_ENABLED=false

# 可观测性（本地开发关闭追踪）
PROMETHEUS_METRICS_ENABLED=true
OTEL_ENABLED=false

# Kong（本地开发不使用）
KONG_ADMIN_URL=http://localhost:8001
