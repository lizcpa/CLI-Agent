# =============================================================================
# ProdVideo AI Factory — 生产环境配置模板
# 警告：生产环境必须通过 secret manager（Vault）或 CI/CD secrets 注入密码，
#       不要直接在 .env 文件中存储真实密码。
#       复制此文件为 .env 并填入实际值。
# =============================================================================

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=<change-me-in-production>
REDIS_DB=0

# MySQL
MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_USER=<change-me-in-production>
MYSQL_PASSWORD=<change-me-in-production>
MYSQL_DATABASE=prodvideo

# Celery
CELERY_BROKER_URL=redis://:<change-me-in-production>@localhost:6379/1
CELERY_RESULT_BACKEND=redis://:<change-me-in-production>@localhost:6379/0

# MinIO
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=<change-me-in-production>
MINIO_SECRET_KEY=<change-me-in-production>

# MongoDB
MONGODB_HOST=localhost
MONGODB_PORT=27017
MONGODB_DATABASE=prodvideo

# JWT Secret（生产环境必须更换为强随机字符串）
INTERNAL_JWT_SECRET=<change-me-in-production>

# 安全开关
MCP_AUTH_DISABLED=false
NACOS_ENABLED=false
VAULT_ENABLED=false
CONTENT_SAFETY_ENABLED=false

# 可观测性
PROMETHEUS_METRICS_ENABLED=true
OTEL_ENABLED=false

# Kong
KONG_ADMIN_URL=http://localhost:8001

# CORS 允许的来源（逗号分隔，生产环境填具体域名）
# ALLOW_ORIGINS=https://admin.example.com,https://app.example.com
